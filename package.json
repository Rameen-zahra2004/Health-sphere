{
  "name": "health-sphere",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "cross-env NODE_OPTIONS=--max-old-space-size=8192 NEXT_DISABLE_WEBPACK_CACHE=1 next dev",
    "build": "cross-env NODE_OPTIONS=--max-old-space-size=8192 NEXT_DISABLE_WEBPACK_CACHE=1 next build",
    "start": "next start",
    "lint": "eslint app backend --ext .ts,.tsx",
    "backend:build": "tsc -p backend/tsconfig.json",
    "backend:start": "node --max-old-space-size=4096 dist-backend/server.js",
    "backend": "npm run backend:build && npm run backend:start",
    "backend:dev": "nodemon --watch backend --ext ts,json --exec \"npm run backend\""
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@reduxjs/toolkit": "^2.11.2",
    "@tanstack/react-query": "^5.95.2",
    "axios": "^1.14.0",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "jwt-decode": "^4.0.0",
    "lucide-react": "^0.577.0",
    "mongodb": "^7.1.1",
    "mongoose": "^9.2.2",
    "morgan": "^1.10.1",
    "next": "^14.2.35",
    "nodemailer": "^8.0.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.72.1",
    "react-icons": "^5.6.0",
    "react-redux": "^9.2.0",
    "recharts": "^3.8.1",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "winston": "^3.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-rate-limit": "^5.1.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.19.39",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/socket.io": "^3.0.1",
    "cross-env": "^7.0.3",
    "eslint": "^9.38.0",
    "eslint-config-next": "^16.1.6",
    "nodemon": "^3.1.14",
    "postcss": "^8.5.8",
    "ts-node": "^10.9.2",
    "typescript": "^5"
  }
}
